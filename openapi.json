              },
              {
                "type": "null"
              }
            ],
            "title": "Output"
          },
          "output_tokens": {
            "anyOf": [
              {
                "type": "integer"
              },
              {
                "type": "null"
              }
            ],
            "title": "Output Tokens"
          },
          "parent_span_id": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Parent Span Id"
          },
          "span_end_time": {
            "anyOf": [
              {
                "format": "date-time",
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Span End Time"
          },
          "span_id": {
            "title": "Span Id",
            "type": "string"
          },
          "span_kind": {
            "title": "Span Kind",
            "type": "string"
          },
          "span_start_time": {
